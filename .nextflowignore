# Nextflow version ignore file — suppress specific Nextflow releases from the
# version-currency check enforced by .github/workflows/check-nextflow-version.yml
# (which runs bin/check_nextflow_version.py).
#
# Format (one entry per line):
#     <X.Y.Z>                    -> permanent ignore
#     <X.Y.Z> exp:YYYY-MM-DD     -> ignore until YYYY-MM-DD, then warn-and-unignore
#
# Lines beginning with '#' and blank lines are ignored. Entries with a past `exp:`
# date print a warning and are treated as absent, so stale temporary ignores
# cannot accumulate silently.
#
# When the highest-semver upstream Nextflow release matches an active entry,
# the version check falls back to the next-highest non-ignored release.

