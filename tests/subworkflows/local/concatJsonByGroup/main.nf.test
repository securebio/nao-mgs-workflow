import groovy.json.JsonSlurper

nextflow_workflow {

    name "Test workflow CONCAT_JSON_BY_GROUP"
    script "subworkflows/local/concatJsonByGroup/main.nf"
    workflow "CONCAT_JSON_BY_GROUP"
    config "tests/configs/run.config"
    tag "subworkflow"
    tag "downstream"
    tag "concat_json_by_group"

    test("Should combine and rename JSON files by group") {
        tag "expect_success"
        when {
            params {}
            workflow {
                '''
                // Input: tuple(label, sample, file, group)
                // group_x has two samples to test multi-sample combining
                // group_y has one sample to test multi-group separation
                // Includes a non-matching suffix file to verify filtering excludes it
                input[0] = Channel.of(
                    ["sa", "sample_a", file("${projectDir}/test-data/combineSampleJsons/sample_a_fastp.json"), "group_x"],
                    ["sb", "sample_b", file("${projectDir}/test-data/combineSampleJsons/sample_b_fastp.json"), "group_x"],
                    ["sb", "sample_b", file("${projectDir}/test-data/combineSampleJsons/sample_b_fastp.json"), "group_y"],
                    ["sa", "sample_a", file("${projectDir}/test-data/results/run_output_shortread/tiny_test_read_counts.tsv"), "group_x"]
                )
                input[1] = "fastp.json"
                input[2] = "test_output"
                '''
            }
        }
        then {
            assert workflow.success

            // Parse input JSONs for verification
            def slurper = new JsonSlurper()
            def input_a = slurper.parse(file("${projectDir}/test-data/combineSampleJsons/sample_a_fastp.json"))
            def input_b = slurper.parse(file("${projectDir}/test-data/combineSampleJsons/sample_b_fastp.json"))

            // Should produce two groups
            assert workflow.out.groups.size() == 2
            def output_groups = workflow.out.groups.collect { it[0] } as Set
            assert output_groups == ["group_x", "group_y"] as Set

            // Verify output file naming and content for each group
            def expected = [
                group_x: [sample_a: input_a, sample_b: input_b],
                group_y: [sample_b: input_b],
            ]
            workflow.out.groups.each { output ->
                def group = output[0]
                assert path(output[1]).getFileName().toString() == "${group}_test_output.json"
                def combined = slurper.parse(path(output[1]).toFile())
                assert combined.size() == expected[group].size()
                expected[group].each { sample, input_data ->
                    assert combined.containsKey(sample)
                    assert combined[sample].sample == sample
                    assert combined[sample].group == group
                    input_data.each { key, value ->
                        assert combined[sample][key] == value
                    }
                }
            }
        }
    }
}
