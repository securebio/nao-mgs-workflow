nextflow_workflow {

    name "Test subworkflow CHECK_VERSION_COMPATIBILITY"
    script "subworkflows/local/checkVersionCompatibility/main.nf"
    workflow "CHECK_VERSION_COMPATIBILITY"
    tag "check_version_compatibility"
    tag "subworkflow"

    test("Should pass when all versions are equal") {
        tag "expect_success"
        config "tests/configs/run.config"
        when {
            params {}
            workflow {
                """
                input[0] = "${projectDir}/test-data/checkVersionCompatibility/versions-equal"
                input[1] = "${projectDir}/test-data/checkVersionCompatibility/versions-equal"
                """
            }
        }
        then {
            assert workflow.success
            assert workflow.out.pipeline_pyproject_path.flatten().any { path(it).getFileName().toString() == "pyproject.toml" }
            assert workflow.out.index_pyproject_path.flatten().any { path(it).getFileName().toString() == "pyproject.toml" }
        }
    }

    test("Should pass when index is newer but compatible") {
        tag "expect_success"
        config "tests/configs/run.config"
        when {
            params {}
            workflow {
                """
                input[0] = "${projectDir}/test-data/checkVersionCompatibility/index-newer-compatible"
                input[1] = "${projectDir}/test-data/checkVersionCompatibility/index-newer-compatible"
                """
            }
        }
        then {
            assert workflow.success
            assert workflow.out.pipeline_pyproject_path.flatten().any { path(it).getFileName().toString() == "pyproject.toml" }
            assert workflow.out.index_pyproject_path.flatten().any { path(it).getFileName().toString() == "pyproject.toml" }
        }
    }

    test("Should pass with legacy index format") {
        tag "expect_success"
        config "tests/configs/run.config"
        when {
            params {}
            workflow {
                """
                input[0] = "${projectDir}/test-data/checkVersionCompatibility/legacy-format"
                input[1] = "${projectDir}/test-data/checkVersionCompatibility/legacy-format"
                """
            }
        }
        then {
            assert workflow.success
            assert workflow.out.pipeline_pyproject_path.flatten().any { path(it).getFileName().toString() == "pyproject.toml" }
            // Legacy fallback creates a temp file via File.createTempFile("index-pyproject", ".toml"),
            // which guarantees the filename starts with the prefix.
            assert workflow.out.index_pyproject_path.flatten().any { path(it).getFileName().toString().startsWith("index-pyproject") }
        }
    }

    test("Should fail if index is too old for pipeline") {
        tag "expect_failed"
        config "tests/configs/run.config"
        when {
            params {}
            workflow {
                """
                input[0] = "${projectDir}/test-data/checkVersionCompatibility/index-too-old"
                input[1] = "${projectDir}/test-data/checkVersionCompatibility/index-too-old"
                """
            }
        }
        then {
            assert workflow.failed
            // Check for actual error (with version numbers), not source code (with ${variable})
            assert workflow.stdout.any{ it.contains("Index version is older than pipeline minimum") && !it.contains('${') }
            assert !workflow.stdout.any{ it.contains("Pipeline version is older than index minimum") && !it.contains('${') }
            assert !workflow.stdout.any{ it.contains("Invalid version format") && !it.contains('${') }
        }
    }

    test("Should fail if pipeline is too old for index") {
        tag "expect_failed"
        config "tests/configs/run.config"
        when {
            params {}
            workflow {
                """
                input[0] = "${projectDir}/test-data/checkVersionCompatibility/pipeline-too-old"
                input[1] = "${projectDir}/test-data/checkVersionCompatibility/pipeline-too-old"
                """
            }
        }
        then {
            assert workflow.failed
            // Check for actual error (with version numbers), not source code (with ${variable})
            assert !workflow.stdout.any{ it.contains("Index version is older than pipeline minimum") && !it.contains('${') }
            assert workflow.stdout.any{ it.contains("Pipeline version is older than index minimum") && !it.contains('${') }
            assert !workflow.stdout.any{ it.contains("Invalid version format") && !it.contains('${') }
        }
    }

    test("Should fail if index is invalid") {
        tag "expect_failed"
        config "tests/configs/run.config"
        when {
            params {}
            workflow {
                """
                input[0] = "${projectDir}/test-data/checkVersionCompatibility/index-invalid"
                input[1] = "${projectDir}/test-data/checkVersionCompatibility/index-invalid"
                """
            }
        }
        then {
            assert workflow.failed
            // Check for actual error, not source code
            assert !workflow.stdout.any{ it.contains("Index version is older than pipeline minimum") && !it.contains('${') }
            assert !workflow.stdout.any{ it.contains("Pipeline version is older than index minimum") && !it.contains('${') }
            assert workflow.stdout.any{ it.contains("Invalid version format") }
        }
    }

}
