/*
========================================================================================
    Test config for DOWNLOAD_VIRAL_GENOMES with scratch enabled.

    Extends the standard index config with `scratch = true` to exercise Nextflow's
    scratch stage-out path (copy outputs from scratch dir back to work dir).
========================================================================================
*/

includeConfig "index.config"

process {
    withName: DOWNLOAD_VIRAL_GENOMES {
        scratch = true
    }
}
