// profiles.config references params.base_dir for workDir resolution.
params {
    base_dir = "./"
}

// Use the production resources.config so bbmask_resources's memory closure is
// the real one being tested.
includeConfig "${projectDir}/configs/resources.config"

// Containers (so the probe processes have an image to run in).
includeConfig "${projectDir}/configs/containers.config"

// Profile definitions (nf-test.config selects profile = "ec2_local,nf_test").
includeConfig "${projectDir}/configs/profiles.config"

// On CI runners the host only has ~4 cores / ~16 GB RAM, but the closure
// schedules up to 128 GB. Lie to the local executor about available
// resources so its pre-flight check doesn't reject the larger tiers (the
// probe processes only run `echo`/`truncate` — they don't actually consume
// the declared memory).
executor {
    name = 'local'
    cpus = 8
    memory = '256 GB'
}

// Override only the cpus directive for bbmask_resources; the memory closure
// from configs/resources.config is preserved by Nextflow config-block merging.
process {
    withLabel: bbmask_resources {
        cpus = 1
    }
}
