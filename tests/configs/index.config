/*
========================================================================================
    Nextflow config file for running tests
========================================================================================
*/

params {
    mode = "index"

    // Directories
    base_dir = "./" // Parent for working and output directories (can be S3)

    // Other contaminants (phage)
    genome_urls = [
        phage: "https://www.ebi.ac.uk/ena/browser/api/fasta/AF158101.6?range=1-1000" // Enterobacteria phage T4 (AF158101 is the GenBank accession for NC_000866)
    ]

    // URLs for downloading reference genomes etc
    taxonomy_url = "https://nao-testing.s3.amazonaws.com/test-databases/tiny-taxonomy.zip"
    virus_host_db_url = "https://www.genome.jp/ftp/db/virushostdb/virushostdb.daily.tsv"
    human_url = "https://www.ebi.ac.uk/ena/browser/api/fasta/CM000683.2?range=10000000-10001000" // 1kb of human chr21 (CM000683.2 is the ENA accession for NC_000021.9)
    ssu_url = "https://www.ebi.ac.uk/ena/browser/api/fasta/AB065370.1"
    lsu_url = "https://www.ebi.ac.uk/ena/browser/api/fasta/AB065370.1"

    // Other reference files
    host_taxon_db = "${projectDir}/ref/host-taxa.tsv"
    // Empty overrides for integration tests: the tiny virus DB built from
    // `download_virus_taxid` doesn't contain the production overrides' WNV taxid.
    host_infection_overrides = "${projectDir}/test-data/toy-data/virus-taxonomy/test-host-infection-overrides-empty.json"
    contaminants = "${projectDir}/ref/contaminants.fasta.gz"
    adapters = "${projectDir}/ref/adapters.fasta" // Path to adapter file for adapter trimming
    genome_patterns_exclude =  "${projectDir}/ref/hv_patterns_exclude.txt"

    // Kraken DB - https://benlangmead.github.io/aws-indexes/k2
    kraken_db = "https://nao-testing.s3.amazonaws.com/test-databases/tiny-kraken2-db.tar.gz" // Path to tarball containing tiny Kraken reference DB (5.8KB)
    blast_db_name = "https://nao-testing.s3.amazonaws.com/test-databases/tiny_blast_db.tar.gz" // Path to tarball containing tiny BLAST DB for testing

    // "all" so taxid 2847173 returns both RefSeq + GenBank accessions
    assembly_source = "all"
    datasets_summary_extra_args = "--assembly-level complete"
    datasets_download_extra_args = ""
    // Sequence-branch params (used only when virus_source is sequence/both).
    virus_source = "assembly"
    datasets_summary_seq_extra_args = "--complete-only"
    datasets_download_seq_extra_args = ""
    // Real prod excludes influenza (11308), but the tiny test taxonomy has no
    // flu node; 10665 is a virus node present in the fixture that doesn't cover
    // HDV (download_virus_taxid), so the clade filter runs without emptying it.
    sequence_exclude_taxid = "10665"
    // taxid 2847173 returns 2+ assemblies, so with chunk_size=2,
    // we exercise downloading multiple assemblies in one
    // DOWNLOAD_VIRAL_GENOMES task.
    viral_accession_chunk_size = 2

    // K-mer index for the viral screen in RUN
    nucleaze_k = 24

    // Other input values
    virus_taxid = "10239"
    download_virus_taxid = "2847173" // Hepatitis D virus 1 (smallest human-infecting virus genome)
    viral_taxids_exclude_hard = "2731619 2732413 2732411 10841 2169574 585893 38018 1266451 1629671" // Exclude Caudoviricetes, Malgrandaviricetes, Faserviricetes, Microviricetes, Smacoviridae, Picobirnaviridae, Bacteriophage sp., Mulberry vein banding virus (plant), Botrytis cinerea negative-stranded RNA virus 1 (fungal)
    host_taxa_screen = "human" // Host taxa to screen for when building reference virus DB

    // Initializing run params to avoid warnings
    kraken_memory = ""
    classify_dedup_subset = ""
}

includeConfig "${projectDir}/configs/containers.config"
includeConfig "${projectDir}/configs/profiles.config"
includeConfig "${projectDir}/configs/output.config"
includeConfig "${projectDir}/configs/logging.config"
