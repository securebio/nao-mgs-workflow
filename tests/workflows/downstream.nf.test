import static groovy.io.FileType.FILES

// Get expected output files from pyproject.toml
// Replaces {SAMPLE} and {GROUP} wildcards with the provided name
def getExpectedOutputs = { pyprojectPath, workflowKey, sampleOrGroupName ->
    def pyprojectText = pyprojectPath.text
    def key = "expected-outputs-${workflowKey}"
    def sectionMatch = (pyprojectText =~ /${key} = \[([\s\S]*?)\]/)
    def expectedFiles = (sectionMatch[0][1] =~ /"([^"]+)"/).collect { it[1] }
    if (sampleOrGroupName != null) {
        expectedFiles = expectedFiles.collect {
            it.replace("{GROUP}", sampleOrGroupName).replace("{SAMPLE}", sampleOrGroupName)
        }
    }
    return expectedFiles.sort()
}

// Get observed output files, excluding intermediates and trace files
def getObservedOutputs = { outputDir ->
    def excludePatterns = ["intermediates", "intermediates_downstream", "trace", "experimental", "experimental_downstream", "sentinel"]
    def observedFiles = []
    outputDir.eachFileRecurse(FILES) { file ->
        def relPath = outputDir.relativize(file).toString()
        def excluded = excludePatterns.any { pattern -> relPath.contains(pattern) }
        if (!excluded) observedFiles << relPath
    }
    return observedFiles.sort()
}

// Get result file paths for snapshot from expected outputs
def getResultPaths = { outputDir, expectedFiles ->
    return expectedFiles
        .findAll { it.startsWith("results_downstream/") }
        .collect { path(outputDir + "/" + it) }
}

// Verify per-group sentinel.json exists and contains expected fields
def assertSentinelValid = { outputDir, group ->
    def sentinelFile = path("${outputDir}/logging_downstream/${group}_sentinel.json")
    assert sentinelFile.exists() : "${group}_sentinel.json not found"
    def sentinelData = new groovy.json.JsonSlurper().parse(sentinelFile.toFile())
    assert sentinelData.downstreamStartedAt != null : "downstreamStartedAt missing"
    assert sentinelData.downstreamCompletedAt != null : "downstreamCompletedAt missing"
    def timestampFormat = /\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2} UTC \(\+0000\)/
    assert sentinelData.downstreamStartedAt ==~ timestampFormat : "downstreamStartedAt format mismatch"
    assert sentinelData.downstreamCompletedAt ==~ timestampFormat : "downstreamCompletedAt format mismatch"
}

// Verify the trace has a tag column populated with id=... values on every row.
// nf-test overrides trace.file via -with-trace=meta/trace.csv, so the trace lands
// at ${launchDir}/meta/trace.csv during tests (not the logging_downstream/ path used in production).
def assertTraceTagsValid = { launchDir ->
    def trace = new File("${launchDir}/meta/trace.csv")
    assert trace.exists() : "trace not found at ${trace}"
    def lines = trace.text.split("\n").findAll { it.trim() }
    def header = lines[0].split("\t")
    def tagIdx = header.findIndexOf { it == "tag" }
    assert tagIdx >= 0 : "tag column missing from trace header"
    def malformed = lines.drop(1).findAll { line ->
        def tagValue = line.split("\t")[tagIdx]
        def parts = tagValue.split(",")
        // Every part must be `key=value` with non-empty key and a value whose first character
        // is non-whitespace; the first part's key must be `id`.
        !(parts[0] ==~ /id=\S.*/) ||
            parts.any { !(it ==~ /[^=]+=\S.*/) }
    }
    assert malformed.isEmpty() : "Found ${malformed.size()} trace rows with malformed tag: ${malformed.take(3)}"
}

nextflow_pipeline {

    name "Test workflow DOWNSTREAM"
    script "main.nf" // Running from main so we have access to published files
    config "tests/configs/downstream.config"
    tag "workflow"

    test("DOWNSTREAM workflow output should match snapshot") {
        tag "downstream_output"
        tag "main_downstream_output"
        tag "snapshot"
        then {
            assert workflow.success
            // Verify expected outputs match pyproject.toml
            def expected = getExpectedOutputs(path("${projectDir}/pyproject.toml"), "downstream", "tt1")
            def observed = getObservedOutputs(path("${launchDir}/output"))
            assert observed == expected : "Expected ${expected} but got ${observed}"
            // Verify result file contents match snapshot
            def resultPaths = getResultPaths("${launchDir}/output", expected)
            assert snapshot(*resultPaths).match("downstream_output_shortread")
            // Verify experimental downstream output exists
            def experimentalDir = path("${launchDir}/output/experimental_downstream")
            def experimentalFiles = []
            experimentalDir.eachFileRecurse(FILES) { file ->
                experimentalFiles << experimentalDir.relativize(file).toString()
            }
            assert experimentalFiles.size() == 1
            assert experimentalFiles[0] == "tt1_duplicate_reads_similarity.tsv.gz"
            assertSentinelValid("${launchDir}/output", "tt1")
            assertTraceTagsValid("${launchDir}")
        }
    }

    test("ONT DOWNSTREAM workflow output should match snapshot") {
        config "tests/configs/downstream_ont.config"
        tag "downstream_output_ont"
        tag "main_downstream_output_ont"
        tag "snapshot_ont"
        then {
            assert workflow.success
            // Verify expected outputs match pyproject.toml
            def expected = getExpectedOutputs(path("${projectDir}/pyproject.toml"), "downstream-ont", "tt1")
            def observed = getObservedOutputs(path("${launchDir}/output"))
            assert observed == expected : "Expected ${expected} but got ${observed}"
            // Verify result file contents match snapshot
            def resultPaths = getResultPaths("${launchDir}/output", expected)
            assert snapshot(*resultPaths).match("downstream_output_ont")
            // Verify no experimental downstream output for ONT
            // Uses new File() instead of path() because path() fails if the directory doesn't exist
            def experimentalDir = new File("${launchDir}/output/experimental_downstream")
            assert !experimentalDir.exists() || experimentalDir.list().length == 0
            assertSentinelValid("${launchDir}/output", "tt1")
            assertTraceTagsValid("${launchDir}")
        }
    }

    test("Should handle header-only input files") {
        tag "downstream_empty_input"
        tag "empty_input"
        when {
            params {
                input_file = "${projectDir}/test-data/downstream/input_file_empty_only.csv"
            }
        }
        then {
            assert workflow.success
            // Verify expected outputs match pyproject.toml
            def expected = getExpectedOutputs(path("${projectDir}/pyproject.toml"), "downstream", "empty_group")
            def observed = getObservedOutputs(path("${launchDir}/output"))
            assert observed == expected : "Expected ${expected} but got ${observed}"
            // Verify experimental downstream output exists with correct headers
            def experimentalDir = path("${launchDir}/output/experimental_downstream")
            def experimentalFiles = []
            experimentalDir.eachFileRecurse(FILES) { file ->
                experimentalFiles << file
            }
            assert experimentalFiles.size() == 1
            def lines = experimentalFiles[0].linesGzip
            assert lines.size() == 1 // header only, no data rows
            def header = lines[0].split("\t") as List
            assert "sim_dup_exemplar" in header
            assert "sim_dup_group_size" in header
            assertSentinelValid("${launchDir}/output", "empty_group")
            assertTraceTagsValid("${launchDir}")
        }
    }

}
