// Verify the trace has a tag column populated with id=... values on every row.
// nf-test overrides trace.file via -with-trace=meta/trace.csv, so the trace lands
// at ${launchDir}/meta/trace.csv during tests (not the logging/ path used in production).
def assertTraceTagsValid = { launchDir ->
    def trace = new File("${launchDir}/meta/trace.csv")
    assert trace.exists() : "trace not found at ${trace}"
    def lines = trace.text.split("\n").findAll { it.trim() }
    def header = lines[0].split("\t")
    def tagIdx = header.findIndexOf { it == "tag" }
    assert tagIdx >= 0 : "tag column missing from trace header"
    def malformed = lines.drop(1).findAll { line ->
        def tagValue = line.split("\t")[tagIdx]
        def parts = tagValue.split(",")
        // Every part must be `key=value` with a non-empty key (no `=`), and a value whose first
        // character is neither `=` nor whitespace and which contains no further `=`; the first
        // part's key must be `id`. (`,` is excluded by the prior split on `,`.)
        !(parts[0] ==~ /id=[^=\s][^=]*/) ||
            parts.any { !(it ==~ /[^=]+=[^=\s][^=]*/) }
    }
    assert malformed.isEmpty() : "Found ${malformed.size()} trace rows with malformed tag: ${malformed.take(3)}"
}

nextflow_pipeline {

    name "Test workflow INDEX"
    script "main.nf" // Running from main so we have access to published files
    config "tests/configs/index.config"
    tag "workflow"

    test("Should run without failures") {
        tag "index"
        tag "main_index"
        then {
            assert workflow.success
            assertTraceTagsValid("${launchDir}")

            // === MAKE_VIRUS_GENOME_DB outputs ===
            def metadata = path("${launchDir}/output/results/virus-genome-metadata-gid.tsv.gz").csv(sep: "\t", decompress: true)
            assert metadata.rowCount >= 2 :
                "Expected ≥2 metadata rows to prove chunk fan-out (got ${metadata.rowCount}). " +
                "If NCBI now publishes only one HDV assembly, broaden download_virus_taxid in the test config."
            def fastaLines = path("${launchDir}/output/results/virus-genomes-masked.fasta.gz").linesGzip
            assert fastaLines.any { it.startsWith(">") } :
                "Masked FASTA should contain at least one sequence header"
            // Pre-filter assembly metadata should be published with the enumerate
            // schema, so benchmarking can resolve build-time taxid assignments.
            def rawMeta = path("${launchDir}/output/results/virus-genome-metadata-raw.tsv.gz").csv(sep: "\t", decompress: true)
            assert rawMeta.columnNames == ["assembly_accession", "taxid", "organism_name", "source_database", "assembly_status", "release_date"]
            assert rawMeta.rowCount >= 1
        }
    }
}
