import groovy.json.JsonSlurper

// Helper: validate FASTP JSON structure and cross-validate read counts
def checkFastpJson = { json, reads_in, reads_pass, is_pe ->
    assert json.containsKey("summary")
    assert json.containsKey("filtering_result")
    assert json.containsKey("read1_before_filtering")
    assert json.containsKey("read1_after_filtering")
    assert json.containsKey("command")
    // Cross-validate read counts between JSON and FASTQ outputs
    assert json.filtering_result.passed_filter_reads == reads_pass
    assert json.summary.before_filtering.total_reads == reads_in
    assert json.summary.after_filtering.total_reads == reads_pass
    // Sanity-check summary statistics
    assert json.summary.before_filtering.q20_rate >= 0
    assert json.summary.before_filtering.q20_rate <= 1
    assert json.summary.before_filtering.q30_rate >= 0
    assert json.summary.before_filtering.q30_rate <= 1
    if (is_pe) {
        assert json.containsKey("read2_before_filtering")
        assert json.containsKey("read2_after_filtering")
    } else {
        assert !json.containsKey("read2_before_filtering")
        assert !json.containsKey("read2_after_filtering")
        assert !json.containsKey("insert_size")
    }
}

nextflow_process {

    name "Test process FASTP"
    script "modules/local/fastp/main.nf"
    process "FASTP"
    tag "module"
    tag "fastp"

    test("Should run correctly on interleaved data") {
        tag "expect_success"
        tag "interleaved"
        config "tests/configs/run.config"
        setup {
            run("LOAD_SAMPLESHEET") {
                script "subworkflows/local/loadSampleSheet/main.nf"
                process {
                    """
                    input[0] = "${projectDir}/test-data/samplesheet.csv"
                    input[1] = "illumina"
                    input[2] = false
                    """
                }
            }
            run("INTERLEAVE_FASTQ") {
                script "modules/local/interleaveFastq/main.nf"
                process {
                    """
                    input[0] = LOAD_SAMPLESHEET.out.samplesheet
                    """
                }
            }
        }
        when {
            params {
            }
            process {
                '''
                input[0] = INTERLEAVE_FASTQ.out.output
                input[1] = "${params.adapters}"
                input[2] = true
                '''
            }
        }
        then {
            // Should run without failures
            assert process.success
            // Input and output should be valid interleaved FASTQ
            def fastq_in = path(process.out.input[0][1]).fastq
            def fastq_pass = path(process.out.reads[0][1]).fastq
            def fastq_fail = path(process.out.failed[0][1]).fastq
            def reads_in = fastq_in.getNumberOfRecords()
            def reads_pass = fastq_pass.getNumberOfRecords()
            def reads_fail = fastq_fail.getNumberOfRecords()
            assert reads_in % 2 == 0
            assert reads_pass % 2 == 0
            assert reads_fail % 2 == 0
            // Should conserve reads between input and output
            assert reads_pass > 0
            assert reads_pass + reads_fail == reads_in
            // JSON and HTML outputs should exist and be non-empty
            assert process.out.json[0][1] != null
            assert process.out.html[0][1] != null
            def json_path = path(process.out.json[0][1])
            assert json_path.exists()
            assert json_path.size() > 0
            // Parse and validate FASTP JSON
            def json = new JsonSlurper().parse(json_path.toFile())
            checkFastpJson(json, reads_in, reads_pass, true)
        }
    }

    test("Should run correctly on single-end data") {
        tag "expect_success"
        tag "single_end"
        config "tests/configs/run.config"
        setup {
            run("LOAD_SAMPLESHEET") {
                script "subworkflows/local/loadSampleSheet/main.nf"
                process {
                    """
                    input[0] = "${projectDir}/test-data/single-end-samplesheet.csv"
                    input[1] = "illumina"
                    input[2] = true
                    """
                }
            }
            run("COPY_FILE") {
                script "modules/local/copyFile/main.nf"
                process {
                    """
                    input[0] = LOAD_SAMPLESHEET.out.samplesheet
                    input[1] = "input.fastq.gz"
                    """
                }
            }
        }
        when {
            params {
            }
            process {
                '''
                input[0] = COPY_FILE.out
                input[1] = "${params.adapters}"
                input[2] = false
                '''
            }
        }
        then {
            // Should run without failures
            assert process.success
            // Should conserve reads between input and output
            def fastq_in = path(process.out.input[0][1]).fastq
            def fastq_pass = path(process.out.reads[0][1]).fastq
            def fastq_fail = path(process.out.failed[0][1]).fastq
            def reads_in = fastq_in.getNumberOfRecords()
            def reads_pass = fastq_pass.getNumberOfRecords()
            def reads_fail = fastq_fail.getNumberOfRecords()
            assert reads_pass > 0
            assert reads_pass + reads_fail == reads_in
            // JSON and HTML outputs should exist and be non-empty
            assert process.out.json[0][1] != null
            assert process.out.html[0][1] != null
            def json_path = path(process.out.json[0][1])
            assert json_path.exists()
            assert json_path.size() > 0
            // Parse and validate FASTP JSON
            def json = new JsonSlurper().parse(json_path.toFile())
            checkFastpJson(json, reads_in, reads_pass, false)
        }
    }

}
