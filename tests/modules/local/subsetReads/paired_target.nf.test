nextflow_process {

    name "Test process SUBSET_READS_PAIRED_TARGET"
    script "modules/local/subsetReads/main.nf"
    process "SUBSET_READS_PAIRED_TARGET"
    config "tests/configs/run.config"
    tag "module"
    tag "subset_reads_paired_target"

    test("Should pass through all reads when target is greater than total"){
        tag "expect_success"
        when {
            params {}
            process {
                '''
                input[0] = Channel.of(["test",
                    ["${projectDir}/test-data/tiny-index/reads/R1.fastq", "${projectDir}/test-data/tiny-index/reads/R2.fastq"],
                    "${projectDir}/test-data/tiny-index/reads/paired_counts.tsv"])
                input[1] = 100
                input[2] = 42 // Arbitrary seed value
                '''
            }
        }
        then {
            assert process.success
            // Output is a single interleaved file containing all input reads
            def fastq_out = path(process.out.output[0][1]).fastq
            def names_out = fastq_out.readNames as List
            def fastq_r1 = path(process.out.input[0][1][0]).fastq
            def fastq_r2 = path(process.out.input[0][1][1]).fastq
            def names_r1 = fastq_r1.readNames as List
            def names_r2 = fastq_r2.readNames as List
            assert names_out.size() == names_r1.size() + names_r2.size()
            // Interleave order: R1[0], R2[0], R1[1], R2[1], ...
            for (int i = 0; i < names_r1.size(); i++) {
                assert names_out[2*i]     == names_r1[i]
                assert names_out[2*i + 1] == names_r2[i]
            }
        }
    }

    test("Should subset and interleave when target is less than total") {
        tag "expect_success"
        when {
            params {
                readTarget = 10
            }
            process {
                '''
                input[0] = Channel.of(["test",
                    ["${projectDir}/test-data/tiny-index/reads/R1.fastq", "${projectDir}/test-data/tiny-index/reads/R2.fastq"],
                    "${projectDir}/test-data/tiny-index/reads/paired_counts.tsv"])
                input[1] = params.readTarget
                input[2] = 42 // Arbitrary seed value
                '''
            }
        }
        then {
            assert process.success
            def fastq_in_r1 = path(process.out.input[0][1][0]).fastq
            def fastq_in_r2 = path(process.out.input[0][1][1]).fastq
            def names_in_r1 = fastq_in_r1.readNames as List
            def names_in_r2 = fastq_in_r2.readNames as List
            def fastq_out = path(process.out.output[0][1]).fastq
            def names_out = fastq_out.readNames as List
            // Output should be paired (even length) and smaller than total input
            assert names_out.size() % 2 == 0
            assert names_out.size() < names_in_r1.size() + names_in_r2.size()
            def n_pairs_out = (names_out.size() / 2) as int
            def tolerance = 0.1
            assert n_pairs_out >= params.readTarget * (1 - tolerance)
            assert n_pairs_out <= params.readTarget * (1 + tolerance)
            // Each output read pair must align: same ID on both sides
            for (int i = 0; i < n_pairs_out; i++) {
                def r1_name = names_out[2*i]
                def r2_name = names_out[2*i + 1]
                assert r1_name in names_in_r1
                assert r2_name in names_in_r2
                assert r1_name.split(" ")[0] == r2_name.split(" ")[0]
            }
        }
    }

}
