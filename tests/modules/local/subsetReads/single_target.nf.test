nextflow_process {

    name "Test process SUBSET_READS_SINGLE_TARGET"
    script "modules/local/subsetReads/main.nf"
    process "SUBSET_READS_SINGLE_TARGET"
    config "tests/configs/run.config"
    tag "module"
    tag "subset_reads_single_target"

    test("Should return all reads when target is greater than total"){
        tag "expect_success"
        setup {
            run("COUNT_READS") {
                script "modules/local/countReads/main.nf"
                process {
                    '''
                    input[0] = Channel.of(["test", "${projectDir}/test-data/tiny-index/reads/R1.fastq"])
                    input[1] = true
                    '''
                }
            }
        }
        when {
            params {}
            process {
                '''
                input[0] = Channel.of(["test", "${projectDir}/test-data/tiny-index/reads/R1.fastq"]).join(COUNT_READS.out.output)
                input[1] = 100
                input[2] = 42 // Arbitrary seed value
                '''
            }
        }
        then {
            assert process.success
            // Passthrough preserves the input byte-for-byte
            assert path(process.out.input[0][1]).md5 == path(process.out.output[0][1]).md5
        }
    }

    test("Should subset appropriately when target is less than total") {
        tag "expect_success"
        setup {
            run("COUNT_READS") {
                script "modules/local/countReads/main.nf"
                process {
                    '''
                    input[0] = Channel.of(["test", "${projectDir}/test-data/tiny-index/reads/R1.fastq"])
                    input[1] = true
                    '''
                }
            }
        }
        when {
            params {
                readTarget = 10
            }
            process {
                '''
                input[0] = Channel.of(["test", "${projectDir}/test-data/tiny-index/reads/R1.fastq"]).join(COUNT_READS.out.output)
                input[1] = params.readTarget
                input[2] = 42 // Arbitrary seed value
                '''
            }
        }
        then {
            assert process.success
            def fastq_in = path(process.out.input[0][1]).fastq
            def fastq_out = path(process.out.output[0][1]).fastq
            def names_in = fastq_in.readNames
            def names_out = fastq_out.readNames
            assert names_out.size() < names_in.size()
            for (name in names_out){
                assert name in names_in
                assert fastq_out.getRecordByName(name) == fastq_in.getRecordByName(name)
            }
            def tolerance = 0.1
            assert names_out.size() >= params.readTarget * (1 - tolerance)
            assert names_out.size() <= params.readTarget * (1 + tolerance)
        }
    }

}
