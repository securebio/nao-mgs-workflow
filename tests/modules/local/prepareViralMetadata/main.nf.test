nextflow_process {

    name "Test process PREPARE_VIRAL_METADATA"
    script "modules/local/prepareViralMetadata/main.nf"
    process "PREPARE_VIRAL_METADATA"
    tag "module"
    tag "prepare_viral_metadata"

    test("Should prepare metadata with species_taxid and local_filename") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "${projectDir}/test-data/tiny-index/viral-metadata/merged_metadata.tsv"
                input[1] = "${projectDir}/test-data/tiny-index/viral-metadata/virus_db.tsv"
                input[2] = "${projectDir}/test-data/tiny-index/viral-metadata/DUMMY_000000000.0_test_genomic.fna.gz"
                """
            }
        }
        then {
            assert process.success
            // Output metadata should have expected columns
            def meta = path(process.out.metadata[0]).csv(sep: "\t")
            assert "assembly_accession" in meta.columnNames
            assert "species_taxid" in meta.columnNames
            assert "local_filename" in meta.columnNames
            assert meta.rowCount == 1
            // Genomes output directory should exist with symlinked files
            assert path(process.out.genomes[0]).exists()
        }
    }

}
