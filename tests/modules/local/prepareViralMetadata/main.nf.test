nextflow_process {

    name "Test process PREPARE_VIRAL_METADATA"
    script "modules/local/prepareViralMetadata/main.nf"
    process "PREPARE_VIRAL_METADATA"
    tag "module"
    tag "prepare_viral_metadata"

    test("Should add species_taxid and expand to per-genome_id rows via the map") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "${projectDir}/test-data/prepareViralMetadata/merged_metadata.tsv"
                input[1] = "${projectDir}/test-data/prepareViralMetadata/virus_db.tsv"
                input[2] = "${projectDir}/test-data/prepareViralMetadata/accession_map.tsv"
                """
            }
        }
        then {
            assert process.success
            def meta = path(process.out.metadata[0]).csv(sep: "\t", decompress: true)
            assert "assembly_accession" in meta.columnNames
            assert "species_taxid" in meta.columnNames
            assert "genome_id" in meta.columnNames
            // The vestigial local_filename column is gone under the map-driven refactor.
            assert !("local_filename" in meta.columnNames)
            // One assembly (GCA_000000000.0, taxid 12475) with one mapped genome_id.
            assert meta.rowCount == 1
            assert meta.columns["genome_id"][0] == "NC_TEST.1"
            assert meta.columns["species_taxid"][0].toString() == "12475"
        }
    }

}
