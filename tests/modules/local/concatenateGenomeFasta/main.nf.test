nextflow_process {

    name "Test process CONCATENATE_GENOME_FASTA"
    script "modules/local/concatenateGenomeFasta/main.nf"
    process "CONCATENATE_GENOME_FASTA"
    config "tests/configs/index.config"
    tag "module"
    tag "concatenate_genome_fasta"

    // Load shared helper functions
    def shell = new GroovyShell()
    def helpers = shell.parse(new File("tests/helpers/FileHelpers.groovy"))

    test("Drops duplicate-name sequences and keeps first occurrence") {
        // Fixtures contain three FASTA files exercising the three relevant
        // cases for `seqkit rmdup --by-name`:
        //   - same name + different sequence (SHARED_NAME_DIFF_SEQ): keep first occurrence
        //   - same name + identical sequence (SHARED_NAME_SAME_SEQ): keep first occurrence
        //   - different names + identical sequence (DIFF_NAME_SAME_SEQ_A/B): keep both
        // The committed fixtures are plain `.fna` for legibility; gzipFixtureDir
        // produces a temp dir of `.fna.gz` copies so the process consumes the
        // production .gz form. The process concatenates in sorted filename order
        // (GCA_001, GCA_002, GCA_003), so first-occurrence dedup is deterministic.
        tag "expect_success"
        when {
            params {}
            process {
                """
                input[0] = file("${helpers.gzipFixtureDir("${projectDir}/test-data/concatenateGenomeFasta/genomes")}/*.fna.gz")
                """
            }
        }
        then {
            assert process.success
            def fasta = path(process.out[0][0]).fasta
            assert fasta.keySet().sort() == [
                "DIFF_NAME_SAME_SEQ_A",
                "DIFF_NAME_SAME_SEQ_B",
                "SHARED_NAME_DIFF_SEQ",
                "SHARED_NAME_SAME_SEQ",
                "UNIQUE_A",
                "UNIQUE_B",
                "UNIQUE_C",
            ]
            // `--by-name` keeps the first occurrence. SHARED_NAME_DIFF_SEQ first
            // appears in GCA_002 (before GCA_003 in sorted order).
            assert fasta["SHARED_NAME_DIFF_SEQ"] == "AAAAAAAA"
            // Output is in sorted filename order (GCA_001, GCA_002, GCA_003),
            // with GCA_003's duplicate SHARED_NAME_* dropped.
            def headers = path(process.out[0][0]).linesGzip
                .findAll { it.startsWith(">") }
                .collect { it.substring(1) }
            assert headers == [
                "UNIQUE_A",             // GCA_001
                "DIFF_NAME_SAME_SEQ_A",
                "UNIQUE_B",             // GCA_002
                "SHARED_NAME_DIFF_SEQ",
                "SHARED_NAME_SAME_SEQ",
                "UNIQUE_C",             // GCA_003 (SHARED_NAME_* dropped by dedup)
                "DIFF_NAME_SAME_SEQ_B",
            ]
        }
    }

    test("Should fail loudly when given no genome FASTA files") {
        // The empty-input guard must exit 1 rather than emit an empty FASTA.
        tag "expect_failed"
        when {
            params {}
            process {
                """
                input[0] = []
                """
            }
        }
        then {
            assert process.failed
        }
    }

}
