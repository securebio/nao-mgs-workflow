nextflow_process {

    name "Test process DOWNLOAD_VIRAL_GENOMES"
    script "modules/local/downloadViralGenomes/main.nf"
    process "DOWNLOAD_VIRAL_GENOMES"
    tag "module"
    tag "download_viral_genomes"

    // Fixtures hold accessions that ENUMERATE_VIRAL_ACCESSIONS returns for
    // taxid 2847173 (Hepatitis D virus 1):
    //   - test_chunk.txt:     refseq only      -> GCF_018547865.1
    //   - test_chunk_two.txt: refseq + genbank -> GCF_018547865.1 + GCA_018547865.1
    //   - test_chunk_bad.txt: a non-existent accession (failure-mode fixture)
    // If these NCBI assembly accessions are removed or are no longer current,
    // pick new accessions using the command
    // `datasets summary genome taxon 2847173 --assembly-source all --as-json-lines`
    //
    // Each chunk yields ONE combined `<chunk>.fna.gz` plus ONE
    // `<chunk>.map.tsv` (assembly_accession -> genome_id), regardless of how
    // many accessions the chunk contains.

    test("Should download a single-accession chunk (HDV refseq)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 5
                input[4] = "assembly"
                """
            }
        }
        then {
            assert process.success
            // One combined FASTA + one map per chunk.
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
            assert process.out.accession_map.size() == 1
            def amap = path(process.out.accession_map[0]).csv(sep: "\t")
            assert amap.columnNames == ["assembly_accession", "genome_id"]
            assert amap.rowCount >= 1
            assert "GCF_018547865.1" in amap.columns["assembly_accession"].toSet()
            // The map's genome_ids must be exactly the combined FASTA's headers
            // (first token), verifying the awk header-extraction in the module.
            def headers = path(process.out.genomes[0]).linesGzip
                .findAll { it.startsWith(">") }
                .collect { it.substring(1).split(/\s/)[0] }
                .toSet()
            assert amap.columns["genome_id"].toSet() == headers :
                "map genome_ids ${amap.columns['genome_id'].toSet()} != FASTA headers ${headers}"
        }
    }

    test("Should download a two-accession chunk (HDV refseq + genbank)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_two.txt")
                input[1] = "all"
                input[2] = ""
                input[3] = 5
                input[4] = "assembly"
                """
            }
        }
        then {
            assert process.success
            // Still one combined FASTA + one map for the whole chunk.
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
            def amap = path(process.out.accession_map[0]).csv(sep: "\t")
            def accs = amap.columns["assembly_accession"].toSet()
            assert "GCF_018547865.1" in accs
            assert "GCA_018547865.1" in accs
            // Map genome_ids must match the combined FASTA headers even when the
            // chunk spans multiple accessions merged into one combined file.
            def headers = path(process.out.genomes[0]).linesGzip
                .findAll { it.startsWith(">") }
                .collect { it.substring(1).split(/\s/)[0] }
                .toSet()
            assert amap.columns["genome_id"].toSet() == headers :
                "map genome_ids ${amap.columns['genome_id'].toSet()} != FASTA headers ${headers}"
        }
    }

    test("Should fail on non-existent accession") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_bad.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 1  // 1 attempt: fail fast on a bad accession
                input[4] = "assembly"
                """
            }
        }
        then {
            assert process.failed
        }
    }

    test("Should download a sequence chunk (HDV nuccore, sequence mode)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_seq.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 5
                input[4] = "sequence"
                """
            }
        }
        then {
            assert process.success
            // One combined FASTA + one map per chunk, same contract as assembly.
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
            def amap = path(process.out.accession_map[0]).csv(sep: "\t")
            assert amap.columnNames == ["assembly_accession", "genome_id"]
            // Sequence records are their own genome: the map is identity.
            amap.rows.each { assert it["assembly_accession"] == it["genome_id"] }
            // genome_ids match the combined FASTA headers, and include the inputs.
            def headers = path(process.out.genomes[0]).linesGzip
                .findAll { it.startsWith(">") }
                .collect { it.substring(1).split(/\s/)[0] }
                .toSet()
            assert amap.columns["genome_id"].toSet() == headers
            // Both requested accessions present (multi-accession combine; catches
            // a silent partial download).
            assert "NC_059681.1" in headers
            assert "NC_001653.2" in headers
        }
    }

    test("Should download all-source sequences under genbank (sequence mode)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_seq.txt")
                input[1] = "genbank"
                input[2] = ""
                input[3] = 5
                input[4] = "sequence"
                """
            }
        }
        then {
            assert process.success
            // genbank in sequence mode downloads all sources (no --refseq), so
            // the RefSeq accessions still come through.
            def headers = path(process.out.genomes[0]).linesGzip
                .findAll { it.startsWith(">") }
                .collect { it.substring(1).split(/\s/)[0] }
                .toSet()
            assert "NC_059681.1" in headers
        }
    }

    test("Should fail on an invalid assembly_source (sequence mode)") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_seq.txt")
                input[1] = "refseqq"
                input[2] = ""
                input[3] = 1
                input[4] = "sequence"
                """
            }
        }
        then {
            assert process.failed
        }
    }

    test("Should fail on an invalid source_type") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 1
                input[4] = "assembley"
                """
            }
        }
        then {
            assert process.failed
        }
    }

    test("Should download genomes with scratch enabled") {
        tag "expect_success"
        tag "scratch"
        config "tests/configs/scratch_download.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 5
                input[4] = "assembly"
                """
            }
        }
        then {
            assert process.success
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
            assert process.out.accession_map.size() == 1
        }
    }

}
