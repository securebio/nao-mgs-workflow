nextflow_process {

    name "Test process DOWNLOAD_VIRAL_GENOMES"
    script "modules/local/downloadViralGenomes/main.nf"
    process "DOWNLOAD_VIRAL_GENOMES"
    tag "module"
    tag "download_viral_genomes"

    // Fixtures hold accessions that ENUMERATE_VIRAL_ACCESSIONS returns for
    // taxid 2847173 (Hepatitis D virus 1):
    //   - test_chunk.txt:     refseq only      -> GCF_018547865.1
    //   - test_chunk_two.txt: refseq + genbank -> GCF_018547865.1 + GCA_018547865.1
    //   - test_chunk_bad.txt: a non-existent accession (failure-mode fixture)
    // If these NCBI assembly accessions are removed or are no longer current,
    // pick new accessions using the command
    // `datasets summary genome taxon 2847173 --assembly-source all --as-json-lines`
    //
    // Each chunk yields ONE combined `<chunk>.fna.gz` plus ONE
    // `<chunk>.map.tsv` (assembly_accession -> genome_id), regardless of how
    // many accessions the chunk contains.

    test("Should download a single-accession chunk (HDV refseq)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 5
                """
            }
        }
        then {
            assert process.success
            // One combined FASTA + one map per chunk.
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
            assert process.out.accession_map.size() == 1
            def amap = path(process.out.accession_map[0]).csv(sep: "\t")
            assert amap.columnNames == ["assembly_accession", "genome_id"]
            assert amap.rowCount >= 1
            assert "GCF_018547865.1" in amap.columns["assembly_accession"].toSet()
        }
    }

    test("Should download a two-accession chunk (HDV refseq + genbank)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_two.txt")
                input[1] = "all"
                input[2] = ""
                input[3] = 5
                """
            }
        }
        then {
            assert process.success
            // Still one combined FASTA + one map for the whole chunk.
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
            def amap = path(process.out.accession_map[0]).csv(sep: "\t")
            def accs = amap.columns["assembly_accession"].toSet()
            assert "GCF_018547865.1" in accs
            assert "GCA_018547865.1" in accs
        }
    }

    test("Should fail on non-existent accession") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_bad.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 1  // 1 attempt: fail fast on a bad accession
                """
            }
        }
        then {
            assert process.failed
        }
    }

    test("Should download genomes with scratch enabled") {
        tag "expect_success"
        tag "scratch"
        config "tests/configs/scratch_download.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 5
                """
            }
        }
        then {
            assert process.success
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
            assert process.out.accession_map.size() == 1
        }
    }

}
