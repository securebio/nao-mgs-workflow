nextflow_process {

    name "Test process DOWNLOAD_VIRAL_GENOMES"
    script "modules/local/downloadViralGenomes/main.nf"
    process "DOWNLOAD_VIRAL_GENOMES"
    tag "module"
    tag "download_viral_genomes"

    // HDV refseq assembly accession used by the success test below. NCBI
    // assembly accessions are stable, but if NCBI ever bumps this to a new
    // version, regenerate the fixture by re-running ENUMERATE_VIRAL_ACCESSIONS
    // on taxid 2847173 (Hepatitis D virus 1) and taking the first row.

    test("Should download genomes for an accession chunk (HDV)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk.txt")
                input[1] = "refseq"
                input[2] = "--assembly-level complete"
                input[3] = 5
                """
            }
        }
        then {
            assert process.success
            // One accession in -> exactly one .fna.gz out (count guard is in the module).
            assert process.out.genomes.size() == 1
            assert process.out.genomes[0].toString().endsWith('.fna.gz')
        }
    }

    test("Should fail on non-existent accession") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/tests/modules/local/downloadViralGenomes/test_chunk_bad.txt")
                input[1] = "refseq"
                input[2] = ""
                input[3] = 5
                """
            }
        }
        then {
            assert process.failed
        }
    }

}
