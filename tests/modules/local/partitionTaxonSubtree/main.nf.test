nextflow_process {

    name "Test process PARTITION_TAXON_SUBTREE"
    script "modules/local/partitionTaxonSubtree/main.nf"
    process "PARTITION_TAXON_SUBTREE"
    tag "module"
    tag "partition_taxon_subtree"

    test("Should emit root when subtree fits within max_size") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "${projectDir}/test-data/tiny-index/taxonomy/nodes.dmp"
                input[1] = "10239"
                input[2] = 100
                """
            }
        }
        then {
            assert process.success
            def taxids = path(process.out.taxids[0]).text.trim().split("\n").sort()
            assert taxids == ["10239"]
        }
    }

    test("Should split at children when root exceeds max_size") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "${projectDir}/test-data/tiny-index/taxonomy/nodes.dmp"
                input[1] = "10239"
                input[2] = 2
                """
            }
        }
        then {
            assert process.success
            def taxids = path(process.out.taxids[0]).text.trim().split("\n").sort()
            assert taxids == ["10665", "12475"]
        }
    }

    test("Should return self for leaf taxon (2847173)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "${projectDir}/test-data/tiny-index/taxonomy/nodes.dmp"
                input[1] = "2847173"
                input[2] = 100
                """
            }
        }
        then {
            assert process.success
            def taxids = path(process.out.taxids[0]).text.trim().split("\n")
            assert taxids == ["2847173"]
        }
    }

}
