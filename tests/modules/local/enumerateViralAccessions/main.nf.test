nextflow_process {

    name "Test process ENUMERATE_VIRAL_ACCESSIONS"
    script "modules/local/enumerateViralAccessions/main.nf"
    process "ENUMERATE_VIRAL_ACCESSIONS"
    tag "module"
    tag "enumerate_viral_accessions"

    test("Should enumerate assemblies for HDV (taxid 2847173)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "2847173"
                input[1] = "refseq"
                input[2] = "--assembly-level complete"
                input[3] = "assembly"
                """
            }
        }
        then {
            assert process.success
            // the enumerated metadata should have the standardized column header
            def meta = path(process.out.metadata[0]).csv(sep: "\t")
            assert meta.columnNames == ["assembly_accession", "taxid", "organism_name", "source_database", "assembly_status", "release_date"]
            assert meta.rowCount >= 1
            // assembly_status should be populated for every row
            assert meta.columns["assembly_status"].every { it && it != "null" }
            // RefSeq accessions should all start with GCF_
            assert meta.columns["assembly_accession"].every { it.startsWith("GCF_") }
        }
    }

    test("Should enumerate assemblies from both refseq and genbank") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "2847173"
                input[1] = "all"
                input[2] = "--assembly-level complete"
                input[3] = "assembly"
                """
            }
        }
        then {
            assert process.success
            def meta = path(process.out.metadata[0]).csv(sep: "\t")
            assert meta.columnNames == ["assembly_accession", "taxid", "organism_name", "source_database", "assembly_status", "release_date"]
            assert meta.rowCount >= 2
            // Both sources should be represented
            def sources = meta.columns["source_database"].toSet()
            assert "SOURCE_DATABASE_REFSEQ" in sources :
                "Expected RefSeq accessions (got sources: ${sources})"
            assert "SOURCE_DATABASE_GENBANK" in sources :
                "Expected GenBank accessions (got sources: ${sources})"
            // Accession prefix should match source: GCF_ for RefSeq, GCA_ for GenBank
            meta.columns["assembly_accession"].eachWithIndex { acc, i ->
                def src = meta.columns["source_database"][i]
                if (src == "SOURCE_DATABASE_REFSEQ") {
                    assert acc.startsWith("GCF_") : "RefSeq accession should start with GCF_: ${acc}"
                } else {
                    assert acc.startsWith("GCA_") : "GenBank accession should start with GCA_: ${acc}"
                }
            }
        }
    }

    test("Should fail on non-existent taxid (assembly)") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "99999999"
                input[1] = "refseq"
                input[2] = ""
                input[3] = "assembly"
                """
            }
        }
        then {
            assert process.failed
        }
    }

    test("Should fail on non-existent taxid (sequence)") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "99999999"
                input[1] = "refseq"
                input[2] = ""
                input[3] = "sequence"
                """
            }
        }
        then {
            assert process.failed
        }
    }

    test("Should fail on an invalid source_type") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "2847173"
                input[1] = "refseq"
                input[2] = ""
                input[3] = "assembley"
                """
            }
        }
        then {
            assert process.failed
        }
    }

    test("Should enumerate RefSeq sequences for HDV (sequence mode)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "2847173"
                input[1] = "refseq"
                input[2] = ""
                input[3] = "sequence"
                """
            }
        }
        then {
            assert process.success
            def meta = path(process.out.metadata[0]).csv(sep: "\t")
            // Same reconciled schema as the assembly path
            assert meta.columnNames == ["assembly_accession", "taxid", "organism_name", "source_database", "assembly_status", "release_date"]
            assert meta.rowCount >= 1
            // Sequence rows carry no assembly status
            assert meta.columns["assembly_status"].every { !it }
            // Accessions are nucleotide records, not GCA/GCF assemblies
            assert meta.columns["assembly_accession"].every { !it.startsWith("GC") } :
                "Sequence accessions should not be assembly (GCA/GCF) accessions"
            // source_database normalized to the assembly path's vocabulary; --refseq limits to RefSeq
            assert meta.columns["source_database"].every { it == "SOURCE_DATABASE_REFSEQ" } :
                "Expected only RefSeq sources under --refseq (got: ${meta.columns["source_database"].toSet()})"
            // release_date truncated to YYYY-MM-DD
            assert meta.columns["release_date"].every { it ==~ /\d{4}-\d{2}-\d{2}/ } :
                "release_date should be YYYY-MM-DD (got: ${meta.columns["release_date"].toSet()})"
        }
    }

    test("Should enumerate all-source sequences for HDV, warning on genbank (sequence mode)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "2847173"
                input[1] = "genbank"
                input[2] = ""
                input[3] = "sequence"
                """
            }
        }
        then {
            assert process.success
            def meta = path(process.out.metadata[0]).csv(sep: "\t")
            assert meta.columnNames == ["assembly_accession", "taxid", "organism_name", "source_database", "assembly_status", "release_date"]
            // genbank in sequence mode cannot filter to GenBank-only, so it
            // enumerates all sources: GenBank records must be present.
            def sources = meta.columns["source_database"].toSet()
            assert "SOURCE_DATABASE_GENBANK" in sources :
                "Expected GenBank sequences when enumerating all sources (got: ${sources})"
            assert meta.columns["assembly_status"].every { !it }
        }
    }

}
