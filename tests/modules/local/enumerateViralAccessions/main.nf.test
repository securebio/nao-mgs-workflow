nextflow_process {

    name "Test process ENUMERATE_VIRAL_ACCESSIONS"
    script "modules/local/enumerateViralAccessions/main.nf"
    process "ENUMERATE_VIRAL_ACCESSIONS"
    tag "module"
    tag "enumerate_viral_accessions"

    test("Should enumerate accessions for HDV (taxid 2847173)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "2847173"
                input[1] = "refseq"
                input[2] = "--assembly-level complete"
                """
            }
        }
        then {
            assert process.success
            // the enumerated metadata should have the standardized column header
            def meta = path(process.out.metadata[0]).csv(sep: "\t")
            assert meta.columnNames == ["assembly_accession", "taxid", "organism_name", "source_database", "assembly_status", "release_date"]
            assert meta.rowCount >= 1
            // assembly_status should be populated for every row
            assert meta.columns["assembly_status"].every { it && it != "null" }
            // RefSeq accessions should all start with GCF_
            assert meta.columns["assembly_accession"].every { it.startsWith("GCF_") }
        }
    }

    test("Should enumerate accessions from both refseq and genbank") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "2847173"
                input[1] = "all"
                input[2] = "--assembly-level complete"
                """
            }
        }
        then {
            assert process.success
            def meta = path(process.out.metadata[0]).csv(sep: "\t")
            assert meta.columnNames == ["assembly_accession", "taxid", "organism_name", "source_database", "assembly_status", "release_date"]
            assert meta.rowCount >= 2
            // Both sources should be represented
            def sources = meta.columns["source_database"].toSet()
            assert "SOURCE_DATABASE_REFSEQ" in sources :
                "Expected RefSeq accessions (got sources: ${sources})"
            assert "SOURCE_DATABASE_GENBANK" in sources :
                "Expected GenBank accessions (got sources: ${sources})"
            // Accession prefix should match source: GCF_ for RefSeq, GCA_ for GenBank
            meta.columns["assembly_accession"].eachWithIndex { acc, i ->
                def src = meta.columns["source_database"][i]
                if (src == "SOURCE_DATABASE_REFSEQ") {
                    assert acc.startsWith("GCF_") : "RefSeq accession should start with GCF_: ${acc}"
                } else {
                    assert acc.startsWith("GCA_") : "GenBank accession should start with GCA_: ${acc}"
                }
            }
        }
    }

    test("Should fail on non-existent taxid") {
        tag "expect_failed"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "99999999"
                input[1] = "refseq"
                input[2] = ""
                """
            }
        }
        then {
            assert process.failed
        }
    }

}
