// Config used by tests/modules/local/maskRead/resource_allocation.nf.test.
// Purpose: let the test exercise the production MASK_FASTQ_READS closure on
// sparse files that claim multi-GB sizes, without the CI-friendly cap from
// tests/nextflow.config rewriting those allocations to 4c/15.GB.
//
// The closure below intentionally duplicates the one in
// modules/local/maskRead/main.nf because Nextflow's later-config-wins
// override semantics require this config to re-specify the directives it
// wants to unmask. If the production closure is changed, update this test
// config to match.

params {
    base_dir = "./"
}

// Bring in container + profile definitions the test harness expects.
includeConfig "${projectDir}/configs/containers.config"
includeConfig "${projectDir}/configs/profiles.config"

// Lift local-executor caps so a 128.GB ask won't be rejected. Stub-mode
// tasks don't actually consume memory, so this is a scheduling-only lie.
executor {
    cpus = 32
    memory = '1024.GB'
}

process {
    withName: 'MASK_FASTQ_READS' {
        cpus   = 16
        memory = { reads.size() > 10.GB ? 128.GB : reads.size() > 2.GB ? 64.GB : 32.GB }
    }
}
