// Exercises the MASK_FASTQ_READS input-size-aware resource closure.
// Uses stub mode + sparse files to drive `reads.size()` into each branch
// of the closure without creating or streaming multi-GB of real data.
// The stub body in modules/local/maskRead/main.nf echoes task.cpus /
// task.memory_gb so the test can assert on the dispatched values.

nextflow_process {

    name "Test MASK_FASTQ_READS resource allocation closure"
    script "modules/local/maskRead/main.nf"
    process "MASK_FASTQ_READS"
    config "tests/modules/local/maskRead/resource_allocation.config"
    tag "module"
    tag "maskRead"
    tag "resource_allocation"

    test("Allocates 32 GiB + 16 CPUs for < 2 GB input (small bucket)") {
        tag "expect_success"
        options "-stub"
        setup {
            def f = new File("${outputDir}/sparse_1gb.fastq.gz")
            f.parentFile.mkdirs()
            def raf = new java.io.RandomAccessFile(f, "rw")
            raf.setLength(1024L * 1024L * 1024L)  // 1 GiB apparent size
            raf.close()
        }
        when {
            process {
                """
                input[0] = Channel.of(["small", file("${outputDir}/sparse_1gb.fastq.gz")])
                input[1] = 25
                input[2] = 0.55
                """
            }
        }
        then {
            assert process.success
            def log = path(process.out.resource_log[0]).text
            assert log.contains("task.cpus=16")
            assert log.contains("task.memory_gb=32")
        }
    }

    test("Allocates 64 GiB + 16 CPUs for 2-10 GB input (medium bucket)") {
        tag "expect_success"
        options "-stub"
        setup {
            def f = new File("${outputDir}/sparse_5gb.fastq.gz")
            f.parentFile.mkdirs()
            def raf = new java.io.RandomAccessFile(f, "rw")
            raf.setLength(5L * 1024L * 1024L * 1024L)  // 5 GiB apparent size
            raf.close()
        }
        when {
            process {
                """
                input[0] = Channel.of(["medium", file("${outputDir}/sparse_5gb.fastq.gz")])
                input[1] = 25
                input[2] = 0.55
                """
            }
        }
        then {
            assert process.success
            def log = path(process.out.resource_log[0]).text
            assert log.contains("task.cpus=16")
            assert log.contains("task.memory_gb=64")
        }
    }

    test("Allocates 128 GiB + 16 CPUs for > 10 GB input (large bucket)") {
        tag "expect_success"
        options "-stub"
        setup {
            def f = new File("${outputDir}/sparse_15gb.fastq.gz")
            f.parentFile.mkdirs()
            def raf = new java.io.RandomAccessFile(f, "rw")
            raf.setLength(15L * 1024L * 1024L * 1024L)  // 15 GiB apparent size
            raf.close()
        }
        when {
            process {
                """
                input[0] = Channel.of(["large", file("${outputDir}/sparse_15gb.fastq.gz")])
                input[1] = 25
                input[2] = 0.55
                """
            }
        }
        then {
            assert process.success
            def log = path(process.out.resource_log[0]).text
            assert log.contains("task.cpus=16")
            assert log.contains("task.memory_gb=128")
        }
    }
}
