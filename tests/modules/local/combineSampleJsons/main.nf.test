import groovy.json.JsonSlurper

nextflow_process {

    name "Test process COMBINE_SAMPLE_JSONS"
    script "modules/local/combineSampleJsons/main.nf"
    process "COMBINE_SAMPLE_JSONS"
    config "tests/configs/run.config"
    tag "module"
    tag "combine_sample_jsons"

    test("Should combine sample JSONs into a grouped output with injected fields") {
        tag "expect_success"
        when {
            params {}
            process {
                '''
                def json_a = file("${projectDir}/test-data/combineSampleJsons/sample_a_fastp.json")
                def json_b = file("${projectDir}/test-data/combineSampleJsons/sample_b_fastp.json")
                input[0] = ["test_group", [json_a, json_b]]
                input[1] = "fastp.json"
                '''
            }
        }
        then {
            assert process.success
            assert process.out.output[0][0] == "test_group"
            // Parse inputs and output
            def slurper = new JsonSlurper()
            def input_a = slurper.parse(file("${projectDir}/test-data/combineSampleJsons/sample_a_fastp.json"))
            def input_b = slurper.parse(file("${projectDir}/test-data/combineSampleJsons/sample_b_fastp.json"))
            def combined = slurper.parse(path(process.out.output[0][1]).toFile())
            // Should contain both samples with injected fields
            assert combined.size() == 2
            ["sample_a", "sample_b"].each { sample ->
                assert combined.containsKey(sample)
                assert combined[sample].sample == sample
                assert combined[sample].group == "test_group"
            }
            // Original data should be preserved
            def inputs = [sample_a: input_a, sample_b: input_b]
            inputs.each { sample, input_data ->
                input_data.each { key, value ->
                    assert combined[sample][key] == value
                }
            }
        }
    }
}
