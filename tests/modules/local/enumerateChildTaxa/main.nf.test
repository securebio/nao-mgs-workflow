nextflow_process {

    name "Test process ENUMERATE_CHILD_TAXA"
    script "modules/local/enumerateChildTaxa/main.nf"
    process "ENUMERATE_CHILD_TAXA"
    tag "module"
    tag "enumerate_child_taxa"

    test("Should find children for internal node (10239)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "${projectDir}/test-data/tiny-index/taxonomy/nodes.dmp"
                input[1] = "10239"
                """
            }
        }
        then {
            assert process.success
            def taxids = path(process.out.taxids[0]).text.trim().split("\n").sort()
            assert taxids == ["10665", "12475"]
        }
    }

    test("Should return self for leaf taxon (2847173)") {
        tag "expect_success"
        config "tests/configs/index.config"
        when {
            params {}
            process {
                """
                input[0] = "${projectDir}/test-data/tiny-index/taxonomy/nodes.dmp"
                input[1] = "2847173"
                """
            }
        }
        then {
            assert process.success
            def taxids = path(process.out.taxids[0]).text.trim().split("\n")
            assert taxids == ["2847173"]
        }
    }

}
