nextflow_process {

    name "Test process ADD_GENBANK_GENOME_IDS"
    script "modules/local/addGenbankGenomeIDs/main.nf"
    process "ADD_GENBANK_GENOME_IDS"
    config "tests/configs/index.config"
    tag "module"
    tag "add_genbank_genome_ids"

    test("Output is input rows replicated per genome_id, with genome_id appended") {
        tag "expect_success"
        // Fixtures: GCA_A has 2 sequences (SEG_A1, SEG_A2), GCA_B has 1 (SEG_B1).
        when {
            params {}
            process {
                """
                input[0] = file("${projectDir}/test-data/addGenbankGenomeIDs/metadata.tsv")
                input[1] = file("${projectDir}/test-data/addGenbankGenomeIDs/genomes")
                input[2] = "virus-genome"
                """
            }
        }
        then {
            assert process.success
            def in_meta = path(process.out.input[0]).csv(sep: "\t")
            def out_meta = path(process.out.output[0]).csv(sep: "\t", decompress: true)

            // Schema: input columns + `genome_id`.
            assert out_meta.columnNames == in_meta.columnNames + ["genome_id"]

            // For each output row, the input columns match the input row
            // sharing its assembly_accession.
            def in_by_asm = (0..<in_meta.rowCount).collectEntries { i ->
                [(in_meta.columns["assembly_accession"][i]): i]
            }
            (0..<out_meta.rowCount).each { i ->
                def src = in_by_asm[out_meta.columns["assembly_accession"][i]]
                in_meta.columnNames.each { col ->
                    assert out_meta.columns[col][i] == in_meta.columns[col][src]
                }
            }

            // Expected genome_id values, parsed from fixture FASTA headers.
            assert out_meta.columns["genome_id"] == ["SEG_A1", "SEG_A2", "SEG_B1"]
        }
    }

}
