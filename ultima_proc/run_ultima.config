/************************************************
| CONFIGURATION FILE FOR ULTIMA SIMULATED PE RUN |
************************************************/

params {
    mode = "run"

    // Platform: use illumina since we're running simulated paired-end data
    platform = "illumina"

    // Directories
    base_dir = "s3://nao-katherine/ultima-analysis/run_spe_init" // Parent for working and output directories
    ref_dir = "s3://nao-mgs-index/20250825/output/" // Reference/index directory

    // Files
    sample_sheet = "s3://nao-katherine/ultima-analysis/simulated-pe/samplesheet_pe.csv"
    adapters = "${projectDir}/ref/adapters.fasta"

    // Other required parameters
    n_reads_profile = 1000000
    bt2_score_threshold = 20
    bracken_threshold = 1
    random_seed = "17310"
    taxid_artificial = "81077"

    // AWS Batch job queue
    queue = "kstansifer-batch-jq"
}

process.queue = params.queue
includeConfig "${projectDir}/configs/logging.config"
includeConfig "${projectDir}/configs/containers.config"
includeConfig "${projectDir}/configs/resources.config"
includeConfig "${projectDir}/configs/profiles.config"
includeConfig "${projectDir}/configs/output.config"
