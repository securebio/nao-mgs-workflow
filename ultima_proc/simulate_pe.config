/***********************************************
| CONFIGURATION FOR SIMULATED PE GENERATION    |
| Generates R2 = revcomp(R1) for Ultima data   |
***********************************************/

params {
    // Input: single-end samplesheet (sample,fastq)
    sample_sheet = "${projectDir}/samplesheet_ultima.csv"

    // Output: S3 directory for R1/R2 FASTQs and paired-end samplesheet
    // Update this to your desired output location
    output_dir = "s3://nao-katherine/ultima-analysis/simulated-pe/"

    // Required by profiles.config for workDir
    base_dir = "s3://nao-katherine/ultima-analysis/simulated-pe"
}

// Include shared infrastructure configs from the main pipeline
includeConfig "${projectDir}/../configs/containers.config"
includeConfig "${projectDir}/../configs/resources.config"
includeConfig "${projectDir}/../configs/profiles.config"

// AWS Batch job queue — update for your environment
process.queue = "kstansifer-batch-jq"
