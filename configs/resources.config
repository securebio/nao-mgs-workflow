// Specify resources for processes based on labels
process {
    // Single-core processes
    withLabel: single {
        cpus = 1
        memory = 4.GB
    }

    withLabel: single_cpu_16GB_memory {
        cpus = 1
        memory = 16.GB
    }

    withLabel: single_cpu_32GB_memory {
        cpus = 1
        memory = 32.GB
    }

    // Small multi-core processes
    withLabel: xsmall {
        cpus = 4
        memory = 16.GB
    }
    withLabel: small {
        cpus = 8
        memory = 16.GB
    }

    // Large multi-core processes
    withLabel: large {
        cpus = 16
        memory = 32.GB
    }

    // Very large multi-core processes
    withLabel: max {
        cpus = 32
        memory = 64.GB
    }

    withLabel: kraken_resources {
        cpus = 16
        memory = 128.GB
    }

    withLabel: blast_resources {
        cpus = 32
        memory = 256.GB
    }

    withLabel: single_huge_mem {
        cpus = 1
        memory = 128.GB
    }

    // Head-node sentinel processes (WRITE_SENTINEL_RUN, WRITE_SENTINEL_DOWNSTREAM)
    // run with `executor 'local'` and validate published outputs by polling many
    // S3 paths via SentinelUtils.waitForFiles. The cap binds in practice on the
    // per-group WRITE_SENTINEL_DOWNSTREAM fan-out (WRITE_SENTINEL_RUN only fires
    // once per workflow), preventing the burst of HEAD requests from exceeding
    // S3's per-prefix request-rate threshold. Belt-and-suspenders alongside the
    // SDK-level `aws.client.maxConnections` cap in configs/profiles.config; this
    // also pins the protection at the sentinel layer so future tuning of the
    // SDK pool does not silently undo it. See issue #801.
    withLabel: sentinel {
        maxForks = 10
    }

    // Input-size-aware tiering for BBMask on gzipped FASTQ. Peak memory scales
    // ~linearly with input bases at small sizes and sub-linearly at large sizes;
    // tier thresholds are the gzipped-FASTQ byte size. See PR #737.
    withLabel: bbmask_resources {
        cpus = 16
        memory = {
            def thresholds = ['2 GB', '10 GB']
            def memories = ['32 GB', '64 GB', '128 GB']
            long bytes = (reads instanceof List) ? reads.sum { r -> r.size() } : reads.size()
            def idx = thresholds.findIndexOf { t -> bytes <= nextflow.util.MemoryUnit.of(t).toBytes() }
            return nextflow.util.MemoryUnit.of(idx >= 0 ? memories[idx] : memories.last())
        }
    }
}
