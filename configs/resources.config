import nextflow.util.MemoryUnit
import java.nio.file.Path

// Helper for resource labels whose peak memory scales with input byte size.
// Lives in this config (rather than lib/*.groovy) because Nextflow's `lib/`
// auto-loading adds classes to the script classpath but NOT the config
// classpath; a `memory = { ... }` closure under `withLabel:` can't resolve
// lib/ classes.
class ResourceTierUtils {
    // Pick a memory tier from process input(s) whose peak memory scales with total byte size.
    //   input:      a Path or List<Path> (a Nextflow `path(...)` process input). Byte sizes
    //               are summed across lists.
    //   thresholds: ascending byte boundaries as memory strings (e.g. ["2 GB", "10 GB"]).
    //   memories:   memory strings for each tier; size == thresholds.size() + 1.
    //               Returns memories[i] for the smallest i with bytes <= thresholds[i];
    //               falls back to memories.last() when bytes exceeds every threshold.
    static MemoryUnit pickMemoryTier(Object input, List<String> thresholds, List<String> memories) {
        if (memories.size() != thresholds.size() + 1) {
            throw new IllegalArgumentException(
                "pickMemoryTier: memories.size() (${memories.size()}) must equal " +
                "thresholds.size() + 1 (${thresholds.size() + 1})")
        }
        long bytes = (input instanceof List)
            ? ((List) input).sum { ((Path) it).size() }
            : ((Path) input).size()
        for (int i = 0; i < thresholds.size(); i++) {
            if (bytes <= MemoryUnit.of(thresholds[i]).toBytes()) return MemoryUnit.of(memories[i])
        }
        return MemoryUnit.of(memories.last())
    }

    // Pick a cpu tier from process input(s) whose work scales with total byte size.
    //   input:      a Path or List<Path> (a Nextflow `path(...)` process input). Byte sizes
    //               are summed across lists.
    //   thresholds: ascending byte boundaries as memory strings (e.g. ["2 GB", "20 GB"]).
    //   cpuTiers:   integer cpu counts for each tier; size == thresholds.size() + 1.
    //               Returns cpuTiers[i] for the smallest i with bytes <= thresholds[i];
    //               falls back to cpuTiers.last() when bytes exceeds every threshold.
    static int pickCpuTier(Object input, List<String> thresholds, List<Integer> cpuTiers) {
        if (cpuTiers.size() != thresholds.size() + 1) {
            throw new IllegalArgumentException(
                "pickCpuTier: cpuTiers.size() (${cpuTiers.size()}) must equal " +
                "thresholds.size() + 1 (${thresholds.size() + 1})")
        }
        long bytes = (input instanceof List)
            ? ((List) input).sum { ((Path) it).size() }
            : ((Path) input).size()
        for (int i = 0; i < thresholds.size(); i++) {
            if (bytes <= MemoryUnit.of(thresholds[i]).toBytes()) return cpuTiers[i]
        }
        return cpuTiers.last()
    }
}

// Specify resources for processes based on labels
process {
    // Single-core processes
    withLabel: single {
        cpus = 1
        memory = 4.GB
    }

    withLabel: single_cpu_16GB_memory {
        cpus = 1
        memory = 16.GB
    }

    withLabel: single_cpu_32GB_memory {
        cpus = 1
        memory = 32.GB
    }

    // Small multi-core processes
    withLabel: xsmall {
        cpus = 4
        memory = 16.GB
    }
    withLabel: small {
        cpus = 8
        memory = 16.GB
    }

    // Large multi-core processes
    withLabel: large {
        cpus = 16
        memory = 32.GB
    }

    // Very large multi-core processes
    withLabel: max {
        cpus = 32
        memory = 64.GB
    }

    withLabel: kraken_resources {
        cpus = 16
        memory = 128.GB
    }

    withLabel: blast_resources {
        cpus = 32
        memory = 256.GB
    }

    withLabel: single_huge_mem {
        cpus = 1
        memory = 128.GB
    }

    // Input-size-aware tiering for BBMask on gzipped FASTQ. Peak memory scales
    // ~linearly with input bases at small sizes and sub-linearly at large sizes;
    // tier thresholds are the gzipped-FASTQ byte size. See PR #737.
    withLabel: bbmask_resources {
        cpus = 16
        memory = { ResourceTierUtils.pickMemoryTier(
            reads,
            ['2 GB', '10 GB'],
            ['32 GB', '64 GB', '128 GB'],
        ) }
    }

    // Input-size-aware tiering for rapidgzip in COUNT_READS. rapidgzip's
    // single-threaded mode is already ~3.8× faster than zcat (better inflate
    // implementation), so small samples get 1 cpu and still win on wall
    // without any cpu-hours regression. Larger samples get 8 cpus to take
    // advantage of rapidgzip's parallel block-boundary inflate. Threshold
    // is the total gzipped byte size (R1+R2 summed).
    withLabel: count_reads_resources {
        cpus = { ResourceTierUtils.pickCpuTier(
            reads,
            ['2 GB'],
            [1, 8],
        ) }
        memory = 4.GB
    }
}
