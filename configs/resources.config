// Specify resources for processes based on labels
process {
    // Single-core processes
    withLabel: single {
        cpus = 1
        memory = 4.GB
    }

    withLabel: single_cpu_16GB_memory {
        cpus = 1
        memory = 16.GB
    }

    withLabel: single_cpu_32GB_memory {
        cpus = 1
        memory = 32.GB
    }

    // Small multi-core processes
    withLabel: xsmall {
        cpus = 4
        memory = 16.GB
    }
    withLabel: small {
        cpus = 8
        memory = 16.GB
    }

    // Large multi-core processes
    withLabel: large {
        cpus = 16
        memory = 32.GB
    }

    // Very large multi-core processes
    withLabel: max {
        cpus = 32
        memory = 64.GB
    }

    withLabel: kraken_resources {
        cpus = 16
        memory = 128.GB
    }

    withLabel: blast_resources {
        cpus = 32
        memory = 256.GB
    }

    withLabel: single_huge_mem {
        cpus = 1
        memory = 128.GB
    }

    // Cap sentinel-fan-out S3 polling concurrency; see #801.
    withLabel: sentinel {
        maxForks = 10
    }

    // Input-size-aware tiering for BBMask on gzipped FASTQ. Peak memory scales
    // ~linearly with input bases at small sizes and sub-linearly at large sizes;
    // tier thresholds are the gzipped-FASTQ byte size. See PR #737.
    withLabel: bbmask_resources {
        cpus = 16
        memory = {
            def thresholds = ['2 GB', '10 GB']
            def memories = ['32 GB', '64 GB', '128 GB']
            long bytes = (reads instanceof List) ? reads.sum { r -> r.size() } : reads.size()
            def idx = thresholds.findIndexOf { t -> bytes <= nextflow.util.MemoryUnit.of(t).toBytes() }
            return nextflow.util.MemoryUnit.of(idx >= 0 ? memories[idx] : memories.last())
        }
    }

    // Input-size-aware tiering for MARK_ALIGNMENT_DUPLICATES on the grouped-hits TSV.
    // mark_duplicates loads every hit row into memory, so peak RSS scales ~linearly with
    // the gzipped TSV size: measured peak_rss ~= 4.2x size across 0.5-8.4 GB of real pooled
    // viral hits. Thresholds keep >=2x headroom at every tier. See PR #737/#836.
    withLabel: mark_alignment_duplicates_resources {
        cpus = 16
        memory = {
            def thresholds = ['3.5 GB', '7 GB']
            def memories = ['32 GB', '64 GB', '128 GB']
            long bytes = (tsv instanceof List) ? tsv.sum { f -> f.size() } : tsv.size()
            def idx = thresholds.findIndexOf { t -> bytes <= nextflow.util.MemoryUnit.of(t).toBytes() }
            return nextflow.util.MemoryUnit.of(idx >= 0 ? memories[idx] : memories.last())
        }
    }

    // Input-size-aware tiering for VSEARCH_CLUSTER on the merged-reads FASTQ. Species are
    // clustered serially in a loop, so peak RSS is driven by the single largest per-species
    // input (hence max(), not sum()). cluster_fast holds all sequences in memory: measured
    // peak_rss ~= 13x the largest gzipped per-species FASTQ (0.5-2 GB, dominant taxon) -
    // higher than previously assumed, so these thresholds are tighter. See PR #737/#836.
    withLabel: vsearch_resources {
        cpus = 16
        memory = {
            def thresholds = ['1.2 GB', '2.4 GB']
            def memories = ['32 GB', '64 GB', '128 GB']
            long bytes = (reads instanceof List) ? reads.max { r -> r.size() }.size() : reads.size()
            def idx = thresholds.findIndexOf { t -> bytes <= nextflow.util.MemoryUnit.of(t).toBytes() }
            return nextflow.util.MemoryUnit.of(idx >= 0 ? memories[idx] : memories.last())
        }
    }
}
