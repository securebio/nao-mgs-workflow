// Specify resources for processes based on labels
process {
    // Single-core processes
    withLabel: single {
        cpus = 1
        memory = 4.GB
    }

    withLabel: single_cpu_16GB_memory {
        cpus = 1
        memory = 16.GB
    }

    withLabel: single_cpu_32GB_memory {
        cpus = 1
        memory = 32.GB
    }

    // Small multi-core processes
    withLabel: xsmall {
        cpus = 4
        memory = 16.GB
    }
    withLabel: small {
        cpus = 8
        memory = 16.GB
    }

    // Large multi-core processes
    withLabel: large {
        cpus = 16
        memory = 32.GB
    }

    // Very large multi-core processes
    withLabel: max {
        cpus = 32
        memory = 64.GB
    }

    withLabel: kraken_resources {
        cpus = 16
        memory = 128.GB
    }

    withLabel: blast_resources {
        cpus = 32
        memory = 256.GB
    }

    withLabel: single_huge_mem {
        cpus = 1
        memory = 128.GB
    }

    // Per-alias overrides: specific process aliases whose resource needs
    // diverge from their module's default label.
    // SORT_MINIMAP2_VIRAL sorts one row per viral minimap2 alignment; on
    // viral-rich ONT libraries its peak memory approaches the 16 GB default
    // (~0.84 ratio observed). Other SORT_TSV aliases peak well below 1 GiB
    // and keep the default tier.
    withName: 'SORT_MINIMAP2_VIRAL' {
        memory = 32.GB
    }
}
