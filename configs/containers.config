// Specify containers for workflow processes
// For Seqera containers, see containers/ directory for build details,
// and rebuild with bin/build_wave_containers.py

// Default rust tools version. This must be defined before use in the process block below,
// so be careful if you move it elsewhere in the stacked config files.
params {
    // Use RUST_TOOLS_VERSION env var if set, otherwise default to "main"
    // This allows CI to override the version without passing Nextflow args through nf-test
    rust_tools_version = System.getenv("RUST_TOOLS_VERSION") ?: "main"
}

process {
    withLabel: BBTools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bbtools:29770b222ed0fe2f"
    }
    withLabel: biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/biopython:07608e13a4a52198"
    }
    withLabel: BLAST {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/blast:957f636801d21682"
    }
    withLabel: bowtie2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bowtie2_samtools:10da5bd6faf23ea7"
    }
    withLabel: bracken_plus_utils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bracken_plus_utils:1a6eceb1342dad6e"
    }
    withLabel: coreutils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils:4cb628807b9a9c3d"
    }
    withLabel: coreutils_file {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_file:a7e9cdf0fbc867e1"
    }
    withLabel: coreutils_gzip_gawk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_gzip_gawk:2b28bcd7454719a7"
    }
    withLabel: curl {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/curl:7ce62fe63144d09f"
    }
    withLabel: fastp {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastp:a08202a50187355d"
    }
    withLabel: FASTQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastqc:b13c26fd7df2ff67"
    }
    withLabel: filtlong {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/filtlong:151f9eacd944b56e"
    }
    withLabel: Kraken2 {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/kraken2:b7c6f526586f5415"
    }
    withLabel: minimap2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/minimap2_samtools:f4f2c3f6de878f3f"
    }
    withLabel: MultiQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/multiqc:ea6a55f48dc7e79a"
    }
    withLabel: ncbi_genome_download {
          container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/ncbi_genome_download:d28b4342e9074862"
    }
    withLabel: pandas {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pandas:ab0f24995e7f446d"
    }
    withLabel: pysam_biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pysam_biopython:1c9c60432ff95d32"
    }
    withLabel: python {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/python:994882f618643ef3"
    }
    withLabel: rpkg {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rpkg:c98d00b7f77624d8"
    }
    withLabel: seqkit {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqkit:ba424e0107aac835"
    }
    withLabel: seqtk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqtk:c6b8c591d9743fb5"
    }
    withLabel: tar_wget {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tar_wget:95508b5c6b8a1695"
    }
    withLabel: tidyverse {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tidyverse:d04302007d17c752"
    }
    withLabel: unzip {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/unzip:6e52d304b1f72bb9"
    }
    withLabel: vsearch {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/vsearch:84da0f794b9d03a5"
    }
    withLabel: rust_tools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rust-tools:${params.rust_tools_version}"
    }
}
