// Specify containers for workflow processes
// For Seqera containers, see containers/ directory for build details,
// and rebuild with bin/build_wave_containers.py

// Default rust tools version. This must be defined before use in the process block below,
// so be careful if you move it elsewhere in the stacked config files.
params {
    // Use RUST_TOOLS_VERSION env var if set, otherwise default to "main"
    // This allows CI to override the version without passing Nextflow args through nf-test
    rust_tools_version = System.getenv("RUST_TOOLS_VERSION") ?: "main"
}

process {
    withLabel: BBTools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bbtools:77cca6c90da914e8"
    }
    withLabel: biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/biopython:e69e55657007e9db"
    }
    withLabel: BLAST {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/blast:5c6c1ddbb75c3cd0"
    }
    withLabel: bowtie2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bowtie2_samtools:fbd96f7bf0239820"
    }
    withLabel: bracken_plus_utils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bracken_plus_utils:8d3762a44ae4f294"
    }
    withLabel: coreutils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils:54b8beef23aecee8"
    }
    withLabel: coreutils_file {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_file:b002dcdd4fcfd6ef"
    }
    withLabel: coreutils_gzip_gawk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_gzip_gawk:075c8368da77897e"
    }
    withLabel: curl {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/curl:f7203c4eedc3b6dd"
    }
    withLabel: fastp {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastp:b973ad172c3bab38"
    }
    withLabel: FASTQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastqc:5f492fc83feb6ca8"
    }
    withLabel: filtlong {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/filtlong:aa58660b5b87835b"
    }
    withLabel: Kraken2 {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/kraken2:95605c38264568b1"
    }
    withLabel: minimap2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/minimap2_samtools:316dfb83ed638735"
    }
    withLabel: MultiQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/multiqc:6dd8dcba8ee128f5"
    }
    withLabel: ncbi_genome_download {
          container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/ncbi_genome_download:3db4c2292105d574"
    }
    withLabel: pandas {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pandas:74e40388d4ca6616"
    }
    withLabel: pysam_biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pysam_biopython:4d1a6d59a2ffe96a"
    }
    withLabel: python {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/python:de975f326161c095"
    }
    withLabel: rpkg {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rpkg:b09ae97cf6dee023"
    }
    withLabel: seqkit {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqkit:f92f2a3d22579c6d"
    }
    withLabel: seqtk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqtk:3eb13af3be6c4c2a"
    }
    withLabel: tar_wget {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tar_wget:149acb82e558a369"
    }
    withLabel: tidyverse {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tidyverse:f3b59b8540e07cc6"
    }
    withLabel: unzip {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/unzip:80631d1363724930"
    }
    withLabel: vsearch {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/vsearch:4b60b6bdbf161de7"
    }
    withLabel: rust_tools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rust-tools:${params.rust_tools_version}"
    }
}
