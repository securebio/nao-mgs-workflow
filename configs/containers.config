// Specify containers for workflow processes
// For Seqera containers, see containers/ directory for build details,
// and rebuild with bin/build_wave_containers.py

// Default rust tools version. This must be defined before use in the process block below,
// so be careful if you move it elsewhere in the stacked config files.
params {
    // Use RUST_TOOLS_VERSION env var if set, otherwise default to "main"
    // This allows CI to override the version without passing Nextflow args through nf-test
    rust_tools_version = System.getenv("RUST_TOOLS_VERSION") ?: "main"
}

process {
    withLabel: BBTools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bbtools:57d91a4e389734c6"
    }
    withLabel: biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/biopython:e95458a7f23d6e35"
    }
    withLabel: BLAST {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/blast:bf4b91a693d13f9f"
    }
    withLabel: bowtie2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bowtie2_samtools:b7023321c1f5bc2c"
    }
    withLabel: bracken_plus_utils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bracken_plus_utils:a02c604fd629e7c5"
    }
    withLabel: coreutils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils:0460c3952a7a03b1"
    }
    withLabel: coreutils_file {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_file:a0fdadd43f49ebbf"
    }
    withLabel: coreutils_gzip_gawk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_gzip_gawk:eb90882a2c724e9c"
    }
    withLabel: curl {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/curl:4f187ed02f77a5ec"
    }
    withLabel: fastp {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastp:9fc223a90cf973af"
    }
    withLabel: FASTQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastqc:32ca1554199ace90"
    }
    withLabel: filtlong {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/filtlong:0371777853dbced9"
    }
    withLabel: Kraken2 {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/kraken2:a6bc09fd639cd047"
    }
    withLabel: minimap2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/minimap2_samtools:bfadf80d7a2c3842"
    }
    withLabel: MultiQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/multiqc:84d4c0737019222e"
    }
    withLabel: ncbi_genome_download {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/ncbi_genome_download:f65ba423abcc7fe5"
    }
    withLabel: pandas {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pandas:fb01150aad97c2c2"
    }
    withLabel: pysam_biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pysam_biopython:66cbf2d4541c586d"
    }
    withLabel: python {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/python:1f76d576c5f5e441"
    }
    withLabel: rpkg {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rpkg:5b219b33a8355cbe"
    }
    withLabel: seqkit {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqkit:de924183b46214a7"
    }
    withLabel: seqtk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqtk:659281f239a533a9"
    }
    withLabel: tar_wget {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tar_wget:f1440eb49029b05a"
    }
    withLabel: tidyverse {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tidyverse:ca446af8e2fe0ced"
    }
    withLabel: unzip {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/unzip:941fb7799a5e041a"
    }
    withLabel: vsearch {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/vsearch:d243366724968e3f"
    }
    withLabel: rust_tools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rust-tools:${params.rust_tools_version}"
    }
}
