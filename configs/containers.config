// Specify containers for workflow processes
// For Seqera containers, see containers/ directory for build details,
// and rebuild with bin/build_wave_containers.py

// Default rust tools version. This must be defined before use in the process block below,
// so be careful if you move it elsewhere in the stacked config files.
params {
    // Use RUST_TOOLS_VERSION env var if set, otherwise default to "main"
    // This allows CI to override the version without passing Nextflow args through nf-test
    rust_tools_version = System.getenv("RUST_TOOLS_VERSION") ?: "main"
}

process {
    withLabel: BBTools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bbtools:9af68ff5fee11b2c"
    }
    withLabel: biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/biopython:c655ac36878d4b53"
    }
    withLabel: BLAST {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/blast:2c02155ffc7b2c18"
    }
    withLabel: bowtie2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bowtie2_samtools:6f4bef9b6a7abc03"
    }
    withLabel: bracken_plus_utils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/bracken_plus_utils:30a0c3c2b2bd982f"
    }
    withLabel: coreutils {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils:c9a2a3ca44651222"
    }
    withLabel: coreutils_file {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_file:7c394033c353e6c0"
    }
    withLabel: coreutils_gzip_gawk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/coreutils_gzip_gawk:67d5d778194c5720"
    }
    withLabel: curl {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/curl:920ab09b80296d9a"
    }
    withLabel: fastp {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastp:e08117b07c0990aa"
    }
    withLabel: FASTQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/fastqc:db3232aa75886d0b"
    }
    withLabel: filtlong {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/filtlong:2927bec69d2f27f0"
    }
    withLabel: Kraken2 {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/kraken2:e7de4b87f2096af6"
    }
    withLabel: minimap2_samtools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/minimap2_samtools:d54843443d9b50cc"
    }
    withLabel: MultiQC {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/multiqc:0fab0623f5b60289"
    }
    withLabel: ncbi_datasets {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/ncbi_datasets:beafafd9a09667f7"
    }
    withLabel: pandas {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pandas:693160bfdfe5e91c"
    }
    withLabel: pysam_biopython {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/pysam_biopython:90b5797433aaf48c"
    }
    withLabel: python {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/python:441bb4bc30cf9e71"
    }
    withLabel: rpkg {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rpkg:62c9f5a8156dfabe"
    }
    withLabel: seqkit {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqkit:8fef08da9c938d7b"
    }
    withLabel: seqtk {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/seqtk:342e340eb68a2f42"
    }
    withLabel: tar_wget {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tar_wget:3592c48ed19bbdf0"
    }
    withLabel: tidyverse {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/tidyverse:a920580857427bbe"
    }
    withLabel: unzip {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/unzip:cb76223935c4d279"
    }
    withLabel: vsearch {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/vsearch:fcc3a5dafa0cf5bf"
    }
    withLabel: rust_tools {
        container = "public.ecr.aws/q0n1c7g8/nao-mgs-workflow/rust-tools:${params.rust_tools_version}"
    }
}
