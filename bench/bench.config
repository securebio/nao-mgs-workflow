// Shared base config for the CONCATENATE_GENOME_FASTA benchmark.
// Per-cohort configs (cohort_single.config, etc.) `includeConfig` this file
// and add their own `process { withName: CONCATENATE_GENOME_FASTA { cpus = N; memory = "M GB" } }`.

params {
    // Inputs: re-use the production-size genome dir + paths file from a prior
    // Riboviria-shard run in nao-jo.
    genome_dir = "s3://nao-jo/mgs-index/work/4b/2c4ac8a11ef199b0b12250d69f87e8/ncbi_genomes"
    paths_file = "s3://nao-jo/mgs-index/work/6f/72b5edfbeb329ef74dd21ea8d514c9/virus-genome-paths.csv"

    // Batch queue + base_dir overridden per-cohort via --base_dir / --queue on the CLI
    queue = "jo-on-demand-batch-jq"
    batch_job_role = ""
}

includeConfig "${projectDir}/configs/profiles.config"
includeConfig "${projectDir}/configs/containers.config"
includeConfig "${projectDir}/configs/resources.config"

process.queue = params.queue

// Stage file-count-heavy processes on local /scratch so the parallel-cp
// staging dir hits local EBS (not Fusion-mounted S3).
process { withName: 'CONCATENATE_GENOME_FASTA|ADD_GENBANK_GENOME_IDS' { scratch = '/scratch' } }

trace {
    enabled = true
    overwrite = true
    fields = "task_id,hash,name,status,exit,realtime,%cpu,cpus,memory,start,complete,duration,rchar,wchar"
}
