config {

    testsDir = "tests"
    workDir = ".nf-test"
    configFile = "tests/nextflow.config"
    // nf_test stacks on ec2_local to surface task failures for negative tests
    // (see configs/profiles.config).
    profile = "ec2_local,nf_test"

    plugins {
        load "nft-csv@0.1.0"
        load "nft-fastq@0.0.1"
        load "nft-fasta@1.0.0"
        load "nft-bam@0.5.0"
    }

}
