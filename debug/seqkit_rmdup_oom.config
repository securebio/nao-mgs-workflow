/***************************************************************************
| CONFIG FOR debug/seqkit_rmdup_oom.nf — seqkit rmdup memory-sweep harness  |
***************************************************************************/

params {
    base_dir = "BASE_DIR_PATH"   // Override on CLI: --base_dir s3://...
    queue    = "BATCH_QUEUE_NAME"  // Override on CLI: --queue <queue>

    // Test input — masked viral-genomes FASTA from the 2026-03-07 reference index.
    // Same unique-sequence-name set as the CONCATENATE_GENOME_FASTA input that OOMs.
    input_fasta = "s3://nao-mgs-index/20260307/output/results/virus-genomes-masked.fasta.gz"

    // Memory tiers (GB) to sweep in parallel.
    memory_tiers_gb = [4, 16, 32, 64]
}

// Relative paths are resolved against this config's own location (debug/),
// so "../configs/..." reaches the project's main config dir regardless of
// what `${projectDir}` resolves to (which depends on the entry script).
includeConfig "../configs/containers.config"
includeConfig "../configs/profiles.config"

process.queue = params.queue
