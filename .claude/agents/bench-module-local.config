// Bench config for the `bench-module-local` agent. The agent copies this
// file into a per-branch worktree and runs Nextflow against the thin
// entrypoint it generates from the module's input signature.
//
// `process.maxForks = 1` is mandatory for clean per-task wall numbers;
// without it, sibling tasks contend for cores and per-sample wall becomes
// contention-noisy. cpu-hours is contention-immune either way.
//
// Production container/resource/param definitions are inherited from the
// repo's own configs so `task.cpus`, `task.memory`, and `params.*` resolve
// correctly for any module under test. When production tiers exceed host
// capacity (e.g. `small`=16GB on a 15GB sandbox), the agent generates a
// per-run override config and passes it as an additional `-c` flag rather
// than mutating this file.

includeConfig "${projectDir}/configs/containers.config"
includeConfig "${projectDir}/configs/resources.config"
includeConfig "${projectDir}/configs/run.config"

// Bench-specific overrides come AFTER the includes — `run.config` transitively
// pulls in `profiles.config` which sets `process.executor = 'awsbatch'`,
// fusion, wave, etc. We override all of those for local execution.
docker.enabled = true
wave.enabled = false
fusion.enabled = false
process.executor = 'local'
process.queue = null
process.maxForks = 1
nextflow.enable.moduleBinaries = true

// `run.config` sets `params.platform = "PLATFORM"` and
// `params.ref_dir = "PATH_TO_REFERENCE_DIRECTORY"` as non-null sentinels that
// don't trigger `?:` elvis defaults — `LOAD_SAMPLESHEET` and any module
// reading `params.ref_dir` reject them. We default both to values appropriate
// for the in-repo tiny-test cohort. Callers override at the CLI when benching
// a different platform or against a different reference dir.
params {
    platform = "illumina"
    ref_dir  = "${projectDir}/test-data/tiny-index/output"
}

// A bench-specific profile the agent passes via `-profile bench_module_local`.
// Its purpose is to suppress Nextflow's auto-activation of the `standard`
// profile from `profiles.config` (which sets `process.executor = "awsbatch"`).
// `docker.runOptions` mounts `$HOME` so modules that read static reference
// assets from a host path (e.g. via `params.ref_dir`) can see them inside the
// container — while NOT referencing `$AWS_ACCESS_KEY_ID` (the `ec2_local`
// profile's interpolation fails under `set -u` when those env vars are unset).
profiles {
    bench_module_local {
        process.executor = 'local'
        wave.enabled = false
        fusion.enabled = false
        docker.runOptions = "-v ${System.getenv('HOME')}:${System.getenv('HOME')}"
    }
}

trace {
    enabled = true
    file = "${params.out_dir}/trace.tsv"
    sep = '\t'
    fields = "task_id,hash,native_id,process,tag,name,status,exit,cpus,submit,start,complete,duration,realtime,%cpu,memory,%mem,vmem,rss,peak_rss,read_bytes,write_bytes"
    overwrite = true
}
